{
  "name": "pinhole",
  "author": "tylxr",
  "description": "Pebble Time 2 app for viewing authenticated security-camera snapshots.",
  "version": "1.2.1",
  "keywords": [
    "pebble-app",
    "pebble",
    "go2rtc",
    "frigate",
    "unifi-protect",
    "security-camera"
  ],
  "private": true,
  "scripts": {
    "build": "pebble build",
    "clean": "pebble clean",
    "install:emery": "pebble install --emulator emery --vnc",
    "test": "node test/snapshot_source_test.js && node test/pkjs_auth_test.js"
  },
  "pebble": {
    "displayName": "PinHole",
    "uuid": "7ce65af2-7686-468d-842e-7ee0c4b27539",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "capabilities": [
      "configurable"
    ],
    "targetPlatforms": [
      "emery"
    ],
    "watchapp": {
      "watchface": false
    },
    "messageKeys": [
      "BaseUrl",
      "CameraList",
      "CacheSeconds",
      "RequestFrame",
      "RequestSeq",
      "CameraIndex",
      "CameraCount",
      "CameraName",
      "FrameSeq",
      "FrameWidth",
      "FrameHeight",
      "FrameTotalBytes",
      "FrameOffset",
      "FrameChunk",
      "FrameChunkSize",
      "FrameComplete",
      "ErrorCode",
      "ErrorMessage"
    ],
    "resources": {
      "media": [
        {
          "type": "png",
          "name": "IMAGE_MENU_ICON",
          "file": "images/menu_icon.png",
          "menuIcon": true
        }
      ]
    }
  }
}
